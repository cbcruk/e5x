{
  "name": "e5x",
  "version": "0.1.0",
  "type": "module",
  "description": "Shape-matched reactive interface over the DOM, in the spirit of E4X.",
  "license": "MIT",
  "author": "cbcruk <cbcruk@gmail.com>",
  "keywords": [
    "dom",
    "e4x",
    "reactive",
    "proxy",
    "shape-matched",
    "live-collection"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx": {
      "types": "./dist/jsx.d.ts",
      "import": "./dist/jsx.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "happy-dom": "^15.11.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^2.1.5"
  }
}
